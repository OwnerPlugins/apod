msgid "APOD Plugin Settings"
msgstr "ការកំណត់កម្មវិធីជំនួយ APOD"

msgid "Cancel"
msgstr "បោះបង់"

msgid "Error building list"
msgstr "កំហុសក្នុងការកសាងបញ្ជី"

msgid "Error displaying image"
msgstr "កំហុសក្នុងការបង្ហាញរូបភាព"

msgid "Error downloading image: {}"
msgstr "កំហុសក្នុងការទាញយករូបភាព៖ {}"

msgid "Error loading data"
msgstr "កំហុសក្នុងការផ្ទុកទិន្នន័យ"

msgid "Error loading data. Try later."
msgstr "កំហុសក្នុងការផ្ទុកទិន្នន័យ។ ព្យាយាមនៅពេលក្រោយ។"

msgid "Failed to download image"
msgstr "បានបរាជ័យក្នុងការទាញយករូបភាព"

msgid "Failed to fetch image: HTTP {}"
msgstr "បានបរាជ័យក្នុងការទៅយករូបភាព៖ HTTP {}"

msgid "Failed to load APOD"
msgstr "បរាជ័យក្នុងការផ្ទុក APOD"

msgid "Failed to load image."
msgstr "បរាជ័យក្នុងការផ្ទុករូបភាព។"

msgid "Fetch mode:"
msgstr "របៀបទៅយក៖"

msgid "Found"
msgstr "បានរកឃើញ"

msgid "Found {} entries"
msgstr "បានរកឃើញធាតុ {}"

msgid "Image not available"
msgstr "រូបភាពមិនមានទេ។"

msgid "Invalid API Key! Please configure a valid NASA API key."
msgstr "សោ API មិនត្រឹមត្រូវ! សូមកំណត់រចនាសម្ព័ន្ធសោរ API របស់ NASA ត្រឹមត្រូវ។"

msgid "Loading Astronomy Picture of the Day..."
msgstr "កំពុងផ្ទុករូបភាពតារាសាស្ត្រនៃថ្ងៃ..."

msgid "Loading fresh APOD data..."
msgstr "កំពុងផ្ទុកទិន្នន័យ APOD ថ្មី..."

msgid "Loading image..."
msgstr "កំពុង​ផ្ទុក​រូបភាព..."

msgid "Loading..."
msgstr "កំពុង​ផ្ទុក..."

msgid "NASA API Key:"
msgstr "គន្លឹះ API របស់ NASA៖"

msgid "No data available. Check API key."
msgstr "មិនមានទិន្នន័យទេ។ ពិនិត្យសោ API ។"

msgid "No image URL available"
msgstr "មិន​មាន​រូបភាព URL ទេ។"

msgid "Number of APODs to fetch:"
msgstr "ចំនួន APODs ដែលត្រូវទៅយក៖"

msgid "Press OK to play video"
msgstr "ចុច យល់ព្រម ដើម្បីចាក់វីដេអូ"

msgid "Random"
msgstr "ចៃដន្យ"

msgid "Recent (date range)"
msgstr "ថ្មីៗ (ជួរកាលបរិច្ឆេទ)"

msgid "Save"
msgstr "រក្សាទុក"

msgid "Search results: {}"
msgstr "លទ្ធផលស្វែងរក៖ {}"

msgid "Search..."
msgstr "ស្វែងរក..."

msgid "Sort order:"
msgstr "តម្រៀបលំដាប់៖"

msgid "Unsupported video URL"
msgstr "URL វីដេអូដែលមិនគាំទ្រ"

msgid "Video playback failed"
msgstr "ការ​ចាក់​វីដេអូ​បាន​បរាជ័យ"
