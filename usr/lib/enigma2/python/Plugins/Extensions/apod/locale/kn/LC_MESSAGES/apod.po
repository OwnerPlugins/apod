msgstr "ವೀಡಿಯೊ ಪ್ಲೇ ಮಾಡಲು ಸರಿ ಒತ್ತಿರಿ"

msgid "Random"
msgstr "ಯಾದೃಚ್ಛಿಕ"

msgid "Recent (date range)"
msgstr "ಇತ್ತೀಚಿನ (ದಿನಾಂಕ ಶ್ರೇಣಿ)"

msgid "Save"
msgstr "ಉಳಿಸಿ"

msgid "Search results: {}"
msgstr "ಹುಡುಕಾಟ ಫಲಿತಾಂಶಗಳು: {}"

msgid "Search..."
msgstr "ಹುಡುಕು..."

msgid "Sort order:"
msgstr "ವಿಂಗಡಿಸುವ ಕ್ರಮ:"

msgid "Unsupported video URL"
msgstr "ಬೆಂಬಲಿತವಲ್ಲದ ವೀಡಿಯೊ URL"

msgid "Video playback failed"
msgstr "ವೀಡಿಯೊ ಪ್ಲೇಬ್ಯಾಕ್ ವಿಫಲವಾಗಿದೆ"
