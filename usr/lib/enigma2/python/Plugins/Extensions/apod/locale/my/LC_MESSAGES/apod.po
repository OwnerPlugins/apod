msgid "Random"
msgstr "ကျပန်း"

msgid "Recent (date range)"
msgstr "လတ်တလော (ရက်စွဲအပိုင်းအခြား)"

msgid "Save"
msgstr "သိမ်းဆည်းပါ။"

msgid "Search results: {}"
msgstr "ရှာဖွေမှုရလဒ်များ- {}"

msgid "Search..."
msgstr "ရှာဖွေပါ..."

msgid "Sort order:"
msgstr "စီရန်-"

