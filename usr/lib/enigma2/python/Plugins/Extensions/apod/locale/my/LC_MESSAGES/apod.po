msgstr "ပုံတင်ရန် မအောင်မြင်ပါ။"

msgid "Fetch mode:"
msgstr "ထုတ်ယူမှုမုဒ်-"

msgid "Found"
msgstr "တွေ့တယ်။"

msgid "Found {} entries"
