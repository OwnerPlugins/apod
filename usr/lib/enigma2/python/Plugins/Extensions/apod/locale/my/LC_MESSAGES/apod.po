msgid "APOD Plugin Settings"
msgstr "APOD ပလပ်အင် ဆက်တင်များ"

msgid "Cancel"
msgstr "မလုပ်တော့"

msgid "Error building list"
msgstr "တည်ဆောက်မှုစာရင်း အမှားအယွင်း"

msgid "Error displaying image"
msgstr "ပုံကိုပြသရာတွင် အမှားအယွင်းရှိသည်။"

msgid "Error downloading image: {}"
msgstr "ပုံဒေါင်းလုဒ်လုပ်ရာတွင် အမှားအယွင်းရှိနေသည်- {}"

msgid "Error loading data"
msgstr "ဒေတာဖွင့်ရာတွင် အမှားအယွင်းရှိသည်။"

msgid "Error loading data. Try later."
msgstr "ဒေတာဖွင့်ရာတွင် အမှားအယွင်းရှိသည်။ နောက်မှကြိုးစားပါ။"

