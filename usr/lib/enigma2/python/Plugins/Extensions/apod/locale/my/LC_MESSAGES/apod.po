msgid "Image not available"
msgstr "ပုံမရရှိနိုင်ပါ။"

msgid "Invalid API Key! Please configure a valid NASA API key."
msgstr "API ကီး မမှန်ပါ။ ကျေးဇူးပြု၍ မှန်ကန်သော NASA API သော့ကို ပြင်ဆင်သတ်မှတ်ပါ။"

msgid "Loading Astronomy Picture of the Day..."
msgstr "နေ့၏ နက္ခတ္တဗေဒ ပုံရိပ်ကို တင်နေသည်..."

msgid "Loading fresh APOD data..."
msgstr "APOD ဒေတာအသစ်ကို တင်နေသည်..."

msgid "Loading image..."
msgstr "ပုံတင်နေသည်..."

msgid "Loading..."
msgstr "ဖွင့်နေသည်..."

msgid "NASA API Key:"
msgstr "NASA API သော့-"

msgid "No data available. Check API key."
