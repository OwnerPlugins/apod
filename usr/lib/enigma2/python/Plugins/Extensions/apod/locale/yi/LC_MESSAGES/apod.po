msgid "APOD Plugin Settings"
msgstr "APOD פּלוגין סעטטינגס"

msgid "Cancel"
msgstr "באָטל מאַכן"

msgid "Error building list"
msgstr "טעות בילדינג רשימה"

msgid "Error displaying image"
msgstr "טעות ווייזן בילד"

msgid "Error downloading image: {}"
msgstr "טעות דאַונלאָודינג בילד: {}"

msgid "Error loading data"
msgstr "טעות לאָודינג דאַטן"

msgid "Error loading data. Try later."
msgstr "טעות לאָודינג דאַטן. פּרוּווט שפּעטער."

msgid "Failed to download image"
msgstr "ניט אַנדערש צו אָפּלאָדירן בילד"

msgid "Failed to fetch image: HTTP {}"
msgstr "ניט געקענט ברענגען בילד: HTTP {}"

msgid "Failed to load APOD"
msgstr "ניט אַנדערש צו לאָדן APOD"

msgid "Failed to load image."
msgstr "ניט אַנדערש צו לאָדן בילד."

msgid "Fetch mode:"
msgstr "ברענגען מאָדע:"

msgid "Found"
msgstr "געפונען"

msgid "Found {} entries"
msgstr "געפונען {} איינסן"

msgid "Image not available"
msgstr "בילד ניט בנימצא"

msgid "Invalid API Key! Please configure a valid NASA API key."
msgstr "אומגילטיגע API שליסל! ביטע קאַנפיגיער אַ גילטיק נאַסאַ אַפּי שליסל."

msgid "Loading Astronomy Picture of the Day..."
msgstr "לאָודינג אַסטראָנאָמיע בילד פון דעם טאָג ..."

msgid "Loading fresh APOD data..."
msgstr "לאָודינג פריש APOD דאַטן ..."

msgid "Loading image..."
