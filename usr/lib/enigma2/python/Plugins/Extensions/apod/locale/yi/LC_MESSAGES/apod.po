msgstr "דרוק OK צו שפּילן ווידעא"

msgid "Random"
msgstr "טראַפ"

msgid "Recent (date range)"
msgstr "לעצטע (דאַטע קייט)"

msgid "Save"
msgstr "היט"

msgid "Search results: {}"
msgstr "זוך רעזולטאטן: {}"

msgid "Search..."
msgstr "זוך..."

msgid "Sort order:"
msgstr "סאָרט סדר:"

